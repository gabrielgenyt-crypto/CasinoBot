# =============================================================================
# CryptoVault Casino Bot — Environment Configuration
# =============================================================================

# --- Discord ---
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Discord Application Client ID
CLIENT_ID=your-client-id-here

# Channel ID for big win announcements (optional)
BIG_WIN_CHANNEL_ID=

# --- Crypto Wallet ---
# BIP39 mnemonic for HD wallet derivation (KEEP THIS SECRET!)
# Generate one with: node -e "const {ethers}=require('ethers');console.log(ethers.Wallet.createRandom().mnemonic.phrase)"
WALLET_MNEMONIC=

# --- Blockchain RPC Endpoints (optional, for provider-based deposit watching) ---
ETH_RPC_URL=
BSC_RPC_URL=
MATIC_RPC_URL=

# --- Webhook (optional, for Alchemy/Moralis deposit notifications) ---
# Secret to validate incoming webhook requests
WEBHOOK_SECRET=
# Port for the webhook HTTP server (default 3000)
WEBHOOK_PORT=3000
